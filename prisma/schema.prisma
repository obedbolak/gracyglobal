// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  
}

// ─── USER ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(USER)
  country       String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  counselorProfile Counselor?
  jobApplications  JobApplication[]
  orders           Order[]
  communityPosts   CommunityPost[]
  bookings         Booking[]
  affiliate        Affiliate?

  @@map("users")
}

enum UserRole {
  USER
  COUNSELOR
  ADMIN
  VOLUNTEER
}

// ─── AUTH (NextAuth) ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── COUNSELORS ──────────────────────────────────────────────────────────────

model Counselor {
  id           String           @id @default(cuid())
  userId       String           @unique
  bio          String?          @db.Text
  specialty    CounselorType[]
  rating       Float            @default(0)
  reviewCount  Int              @default(0)
  pricePerHour Int              @default(0) // in CFA
  available    Boolean          @default(true)
  verified     Boolean          @default(false)
  createdAt    DateTime         @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("counselors")
}

enum CounselorType {
  RELATIONSHIP
  EMOTIONAL_WELLNESS
  LIFE_COACH
  FAMILY
  CAREER
  MENTAL_HEALTH
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  counselorId String
  type        SessionType
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime
  duration    Int           @default(60) // minutes
  price       Int           // in CFA
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id])
  counselor Counselor @relation(fields: [counselorId], references: [id])

  @@map("bookings")
}

enum SessionType {
  TEXT
  VIDEO
  SUPPORT_GROUP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ─── JOBS ────────────────────────────────────────────────────────────────────

model Job {
  id           String         @id @default(cuid())
  title        String
  company      String
  companyLogo  String?
  description  String         @db.Text
  category     JobCategory
  type         JobType        @default(REMOTE)
  salaryMin    Int?           // in CFA
  salaryMax    Int?
  location     String?
  skills       String[]
  active       Boolean        @default(true)
  featured     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  expiresAt    DateTime?

  applications JobApplication[]

  @@map("jobs")
}

enum JobCategory {
  TECH
  MARKETING
  DESIGN
  CUSTOMER_SERVICE
  WRITING
  FINANCE
  EDUCATION
  HEALTH
  OTHER
}

enum JobType {
  REMOTE
  HYBRID
  CONTRACT
  FREELANCE
}

model JobApplication {
  id        String            @id @default(cuid())
  userId    String
  jobId     String
  status    ApplicationStatus @default(APPLIED)
  coverNote String?           @db.Text
  appliedAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@map("job_applications")
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

// ─── MARKETPLACE ─────────────────────────────────────────────────────────────

model Product {
  id          String        @id @default(cuid())
  name        String
  description String        @db.Text
  price       Int           // in CFA
  images      String[]
  category    String
  stock       Int           @default(0)
  featured    Boolean       @default(false)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  total     Int         // in CFA
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── COMMUNITY ───────────────────────────────────────────────────────────────

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  category  String
  tags      String[]
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("community_posts")
}

// ─── STATS ───────────────────────────────────────────────────────────────────

model SiteStat {
  id               String   @id @default(cuid())
  peopleSupported  Int      @default(1000)
  jobsShared       Int      @default(500)
  communityProjects Int     @default(50)
  marketplaceItems Int      @default(10)
  updatedAt        DateTime @updatedAt

  @@map("site_stats")
}


model Affiliate {
  id             String          @id @default(cuid())
  userId         String          @unique
  code           String          @unique   // e.g. "AMINA-X7K2"
  tier           AffiliateTier   @default(STARTER)
  totalReferrals Int             @default(0)
  totalEarnings  Int             @default(0) // in CFA
  pendingPayout  Int             @default(0) // in CFA
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals AffiliateReferral[]
  payouts   AffiliatePayout[]

  @@map("affiliates")
}

enum AffiliateTier {
  STARTER  // 0–10 referrals → 10%
  GROWTH   // 11–50 referrals → 20%
  ELITE    // 51+ referrals → 30%
}

model AffiliateReferral {
  id          String           @id @default(cuid())
  affiliateId String
  referredId  String           @unique  // the User who signed up
  status      ReferralStatus   @default(PENDING)
  commission  Int              @default(0) // CFA earned on this referral
  convertedAt DateTime?
  createdAt   DateTime         @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("affiliate_referrals")
}

enum ReferralStatus {
  PENDING    // clicked link, signed up, no paid action yet
  CONVERTED  // completed first paid action — commission earned
  EXPIRED    // cookie expired without conversion
}

model AffiliatePayout {
  id          String        @id @default(cuid())
  affiliateId String
  amount      Int           // CFA
  method      PayoutMethod
  reference   String?       // bank/MoMo transaction ref
  status      PayoutStatus  @default(PENDING)
  requestedAt DateTime      @default(now())
  processedAt DateTime?

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("affiliate_payouts")
}

enum PayoutMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  PAYPAL
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}