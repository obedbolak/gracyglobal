// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            UserRole[]       @default([USER])
  country         String?
  phone           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  serviceBookings ServiceBooking[]

  postedJobs       Job[]            @relation("PostedJobs") // ← ADD
jobSeekerProfile JobSeeker?       // ← ADD
resume           Resume?
 store  Store?

  // Relations
  accounts         Account[]
  sessions         Session[]
  counselorProfile Counselor?
  jobApplications  JobApplication[]
  orders           Order[]
  communityMembers CommunityMember[] // was: communityMember CommunityMember?
  communityPosts   CommunityPost[]
  postComments     PostComment[]
  postReactions    PostReaction[]
  bookings         Booking[]
  affiliate        Affiliate?
  subscriptions    UserSubscription[]
  payments         Payment[]
  paymentMethods   UserPaymentMethod[]
  enrollments      Enrollment[]
  quizAttempts     QuizAttempt[]
  liveAttendances  LiveAttendance[]
  verificationOTP  VerificationOTP[]
  referredAffiliate AffiliateReferral? @relation("ReferredUser")

  teacherCourses Course[]  @relation("TeacherCourses") // ← ADD THIS LINE
  sellerProducts Product[] @relation("SellerProducts") // ← ADD THIS
  sellerServices Service[] @relation("SellerServices")

  @@map("users")
}

enum UserRole {
  USER
  COUNSELOR
  ADMIN
  VOLUNTEER
  TEACHER // ← NEW
  CREATOR
  MARKETPLACE  // ← NEW

}

// ─── AUTH (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model VerificationOTP {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  phone     String?
  code      String
  type      String
  data      Json?
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_otps")
}

// ─── NEW PRICING SYSTEM ──────────────────────────────────────────────────────

model PricingPlan {
  id       String       @id @default(cuid())
  planCode String       @unique // "C1", "C2", "C3", "M1", "M2", etc.
  category PlanCategory
  name     String // "Monthly", "Yearly", "Free", etc.
  price    Int          @default(0) // in FCFA
  interval PlanInterval

  // Commission & limits
  commissionRate Int? // percentage (null if N/A)
  productLimit   Int? // for marketplace
  leadLimit      Int? // for services
  courseLimit    Int? // for teachers

  // Features
  features String[] // JSON array of feature strings

  // Metadata
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscriptions UserSubscription[]

  @@map("pricing_plans")
}

enum PlanCategory {
  COUNSELLOR
  MARKETPLACE
  SERVICE
  TEACHER
  STUDENT
}

enum PlanInterval {
  MONTHLY
  YEARLY
  ONGOING // for free plans
  PER_LEAD // for pay-per-lead
  PER_USE // for pay-as-you-go
}

// ─── USER SUBSCRIPTIONS ──────────────────────────────────────────────────────

model UserSubscription {
  id     String @id @default(cuid())
  userId String
  planId String

  // Status & billing
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)

  // Usage tracking
  sessionsUsed Int @default(0)
  leadsUsed    Int @default(0)
  productsUsed Int @default(0)
  coursesUsed  Int @default(0)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     PricingPlan @relation(fields: [planId], references: [id])
  payments Payment[]

  @@unique([userId, planId]) // one subscription per plan per user
  @@index([status]) // ← ADD THIS
  @@index([userId, status])
  @@map("user_subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
}

// ─── PAYMENTS ────────────────────────────────────────────────────────────────

model Payment {
  id             String  @id @default(cuid())
  userId         String
  subscriptionId String? // null for one-time payments

  // Payment details
  amount    Int // in FCFA
  currency  String        @default("XAF")
  method    PaymentMethod
  reference String? // transaction ID from payment provider

  // Status
  status PaymentStatus @default(PENDING)
  paidAt DateTime?

  // Metadata
  description String?
  metadata    Json? // store additional payment info
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  //webhooks & retries
  webhookData   Json?
  webhookStatus String?

  // Relations
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  commission   AffiliateCommission?

  @@index([userId, createdAt])
  @@map("payments")
}

model UserPaymentMethod {
  id        String        @id @default(cuid())
  userId    String
  method    PaymentMethod
  label     String
  details   Json?
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_payment_methods")
}

enum PaymentMethod {
  MOBILE_MONEY_MTN
  MOBILE_MONEY_ORANGE
  BANK_TRANSFER
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

// ─── USAGE TRACKING (Optional but recommended) ───────────────────────────────

model UsageLog {
  id             String  @id @default(cuid())
  userId         String
  subscriptionId String?

  // What was used
  type        UsageType
  quantity    Int       @default(1)
  description String?

  // Metadata
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("usage_logs")
}

enum UsageType {
  SESSION
  LEAD
  PRODUCT_LISTED
  COURSE_UPLOADED
  COMMISSION_CHARGED
}

// ─── COUNSELORS ──────────────────────────────────────────────────────────────

model Counselor {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?  @db.Text
  specialty    String
  rating       Float    @default(0)
  reviews      Int      @default(0)
  pricePerHour Int      @default(0)
  available    Boolean  @default(true)
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("counselors")
}

enum CounselorType {
  RELATIONSHIP
  EMOTIONAL_WELLNESS
  LIFE_COACH
  FAMILY
  CAREER
  MENTAL_HEALTH
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  counselorId String
  type        SessionType
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime
  duration    Int           @default(60)
  price       Int
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id])
  counselor Counselor @relation(fields: [counselorId], references: [id])

  @@map("bookings")
}

enum SessionType {
  TEXT
  VIDEO
  SUPPORT_GROUP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}
model JobCategoryModel {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  icon        String?
  color       String?
  description String?
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  jobs        Job[]       @relation("JobCategoryRelation")

  @@index([active])
  @@index([slug])
  @@map("job_categories")
}

model JobSeeker {
  id             String      @id @default(cuid())
  userId         String      @unique
  name           String
  email          String
  phone          String?
  category       JobCategory
  type           JobType
  expectedSalary Int?
  location       String?
  skills         String[]
  experience     String      @db.Text
  portfolio      String?
  resume         String?
  availability   String?
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category, type])
  @@index([active])
  @@map("job_seekers")
}
// ─── JOBS ────────────────────────────────────────────────────────────────────

model Job {
  id          String      @id @default(cuid())
  title       String
  company     String
  companyLogo String?
  description String      @db.Text
  category    JobCategory
  type        JobType     @default(REMOTE)
  salaryMin   Int?
  salaryMax   Int?
  location    String?
  skills      String[]
  active      Boolean     @default(true)
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  expiresAt   DateTime?

  jobCategoryId   String?              // ← ADD
  jobCategory     JobCategoryModel?    @relation("JobCategoryRelation", fields: [jobCategoryId], references: [id], onDelete: SetNull)


  posterId    String?     // ← OPTIONAL with ?
  poster      User?       @relation("PostedJobs", fields: [posterId], references: [id], onDelete: Cascade) // ← OPTIONAL with ?

  applications JobApplication[]
    @@index([jobCategoryId])
  @@map("jobs")
}

enum JobCategory {
  TECH
  MARKETING
  DESIGN
  CUSTOMER_SERVICE
  WRITING
  FINANCE
  EDUCATION
  HEALTH
  OTHER
}

enum JobType {
  REMOTE
  HYBRID
  CONTRACT
  FREELANCE
}

model JobApplication {
  id        String            @id @default(cuid())
  userId    String
  jobId     String
  status    ApplicationStatus @default(APPLIED)
  coverNote String?           @db.Text
  appliedAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])


  @@unique([userId, jobId])
  @@map("job_applications")
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

// product categories 
model ProductCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?  // emoji
  image     String?  // URL from Cloudinary or any image host
  color     String?  // accent hex e.g. "#7b2fbe"
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   products  Product[] 
  @@index([slug])
  @@index([active, sortOrder])
  @@map("product_categories")
}

// ─── MARKETPLACE ─────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  sellerId    String? // ← ADD THIS
  description String   @db.Text
  price       Int
  images      String[]
  categoryId  String   // Changed from category String  group       String   @default("")
  stock       Int      @default(0)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  rating      Float    @default(0)
  reviews     Int      @default(0)
  badge       String?
  benefits    String[]
  ingredients String[]
  group       String   @default("")
  createdAt   DateTime @default(now())

  orderItems OrderItem[]
  category   ProductCategory @relation(fields: [categoryId], references: [id])
  seller     User?       @relation("SellerProducts", fields: [sellerId], references: [id]) // ← ADD THIS


  @@index([categoryId])
  @@index([sellerId])
  @@index([active, featured])
  @@index([createdAt])
  @@map("products")
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  total        Int
  status       OrderStatus @default(PENDING)
  cancelReason String?     // Reason for cancellation
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── COMMUNITY POSTS ─────────────────────────────────────────────────────────

model CommunityPost {
  id          String   @id @default(cuid())
  userId      String
  communityId String
  title       String? // optional — not all posts need a title
  content     String?  @db.Text // text/caption
  category    String? // e.g. "Announcement", "Discussion", "Resource"
  type        PostType @default(TEXT)

  // media
  mediaUrl    String? // image, video, or document URL (from Cloudinary)
  mediaType   String? // e.g. "image/jpeg", "video/mp4", "application/pdf"
  linkUrl     String? // for LINK type posts
  linkPreview Json? // { title, description, image, url } scraped from link

  tags      String[]
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id])
  community Community      @relation(fields: [communityId], references: [id])
  comments  PostComment[]  @relation("PostComments")
  reactions PostReaction[] @relation("PostReactions")

  @@map("community_posts")
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  LINK
}

// ─── COMMUNITY ───────────────────────────────────────────────────────────────

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  image       String?
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members CommunityMember[]
  posts   CommunityPost[]

  @@map("communities")
}

// ── UPDATED: now links to a specific community, removed @unique on userId ──
model CommunityMember {
  id          String     @id @default(cuid())
  userId      String
  communityId String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId]) // one membership per community per user
  @@map("community_members")
}

enum MemberRole {
  MEMBER
  MODERATOR
  ADMIN
}

// ── NEW: comments on posts ──
model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  communityPost CommunityPost @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_comments")
}

// ── NEW: reactions on posts ──
model PostReaction {
  id     String       @id @default(cuid())
  postId String
  userId String
  type   ReactionType

  communityPost CommunityPost @relation("PostReactions", fields: [postId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type]) // one reaction type per user per post
  @@map("post_reactions")
}

enum ReactionType {
  LIKE
  LOVE
  SUPPORT
}

// ─── STATS ───────────────────────────────────────────────────────────────────

model SiteStat {
  id                String   @id @default(cuid())
  peopleSupported   Int      @default(1000)
  jobsShared        Int      @default(500)
  communityProjects Int      @default(50)
  marketplaceItems  Int      @default(10)
  updatedAt         DateTime @updatedAt

  @@map("site_stats")
}

// ─── AFFILIATE ───────────────────────────────────────────────────────────────

model Affiliate {
  id             String        @id @default(cuid())
  userId         String        @unique
  code           String        @unique
  tier           AffiliateTier @default(STARTER)
  commissionRate Float         @default(0.20) // 20% default
  totalReferrals Int           @default(0)
  totalEarnings  Int           @default(0) // in XAF, all-time
  pendingPayout  Int           @default(0) // in XAF, awaiting payout
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals   AffiliateReferral[]
  commissions AffiliateCommission[]
  payouts     AffiliatePayout[]

  @@map("affiliates")
}

enum AffiliateTier {
  STARTER
  GROWTH
  ELITE
}

// One record per referred user
model AffiliateReferral {
  id             String         @id @default(cuid())
  affiliateId    String
  referredUserId String         @unique // the user who signed up via the link
  status         ReferralStatus @default(PENDING)
  convertedAt    DateTime?      // when they first paid
  createdAt      DateTime       @default(now())

  affiliate   Affiliate             @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUser User                 @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  commissions AffiliateCommission[]

  @@map("affiliate_referrals")
}

enum ReferralStatus {
  PENDING    // signed up but never paid
  CONVERTED  // made at least one payment
  EXPIRED
}

// One record per subscription payment — recurring commissions
model AffiliateCommission {
  id         String           @id @default(cuid())
  affiliateId String
  referralId  String
  payoutId    String?          // ← ADD THIS
  paymentId   String           @unique // the Payment that triggered this
  amount      Int              // commission in XAF
  status      CommissionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  approvedAt  DateTime?

  affiliate Affiliate        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
    payout    AffiliatePayout?  @relation("PayoutCommissions", fields: [payoutId], references: [id]) // ← ADD THIS
  referral  AffiliateReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  payment   Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([affiliateId, status])
  @@map("affiliate_commissions")
}

enum CommissionStatus {
  PENDING   // payment received, not yet approved
  APPROVED  // ready to be paid out
  PAID      // included in a payout
  CANCELLED // payment was refunded/failed
}

model AffiliatePayout {
  id          String       @id @default(cuid())
  affiliateId String
  amount      Int
  method      PayoutMethod
  reference   String?
  status      PayoutStatus @default(PENDING)
  requestedAt DateTime     @default(now())
  processedAt DateTime?

  affiliate   Affiliate             @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  commissions AffiliateCommission[] @relation("PayoutCommissions")
    

  @@map("affiliate_payouts")
}

enum PayoutMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  PAYPAL
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

model CourseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  image     String?
  color     String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]

  @@index([slug])
  @@index([active, sortOrder])
  @@map("course_categories")
}

// ─── E-LEARNING ──────────────────────────────────────────────────────────────

model Course {
  id          String      @id @default(cuid())
  title       String
  description String      @db.Text
  thumbnail   String?
  categoryId  String
  level       CourseLevel @default(BEGINNER)
  price       Int         @default(0) // 0 = free, CFA
  isFree      Boolean     @default(false)
  published   Boolean     @default(false)
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  teacherId String? // ← ADD THIS
  teacher   User?   @relation("TeacherCourses", fields: [teacherId], references: [id]) // ← ADD THIS
  category  CourseCategory @relation(fields: [categoryId], references: [id])

  sections    CourseSection[]
  enrollments Enrollment[]
  liveSession LiveSession?

   @@index([categoryId])
  @@index([teacherId])
  @@index([published, featured])
  @@index([createdAt])
  @@map("courses")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model CourseSection {
  id       String @id @default(cuid())
  courseId String
  title    String
  order    Int

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("course_sections")
}

model Lesson {
  id          String     @id @default(cuid())
  sectionId   String
  title       String
  type        LessonType
  content     String?    @db.Text // TEXT lessons
  documentUrl String?    // ← ADD THIS
  videoUrl    String? // VIDEO lessons
  duration    Int? // minutes
  order       Int
  isFree      Boolean    @default(false) // preview lesson
  publishedAt DateTime?
  createdAt   DateTime   @default(now())

  section  CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quiz     Quiz?
  progress LessonProgress[]

  @@map("lessons")
}

enum LessonType {
  VIDEO
  TEXT
  DOCUMENT
  QUIZ
  LIVE
}

// ─── QUIZZES ─────────────────────────────────────────────────────────────────

model Quiz {
  id           String @id @default(cuid())
  lessonId     String @unique
  passingScore Int    @default(70) // percentage

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id       String   @id @default(cuid())
  quizId   String
  question String   @db.Text
  options  String[]
  answer   Int // index of correct option
  order    Int

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  answers     Int[] // selected option indexes
  score       Int // percentage
  passed      Boolean
  attemptedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

// ─── LIVE SESSIONS ───────────────────────────────────────────────────────────

model LiveSession {
  id          String            @id @default(cuid())
  courseId    String            @unique
  title       String
  description String?           @db.Text
  scheduledAt DateTime
  duration    Int               @default(60) // minutes
  meetingUrl  String?
  status      LiveSessionStatus @default(SCHEDULED)
  createdAt   DateTime          @default(now())

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendances LiveAttendance[]

  @@map("live_sessions")
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveAttendance {
  id            String   @id @default(cuid())
  liveSessionId String
  userId        String
  joinedAt      DateTime @default(now())

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, userId])
  @@map("live_attendances")
}

// ─── ENROLLMENT & PROGRESS ───────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  paidAmount  Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([userId, courseId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model LessonProgress {
  id           String    @id @default(cuid())
  enrollmentId String
  lessonId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?
  watchedSecs  Int       @default(0) // video lessons

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@map("lesson_progress")
}


model ServiceCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  image     String?
  color     String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]

 @@index([slug])
  @@index([active, sortOrder])
  @@map("service_categories")
}

// ─── SERVICES ────────────────────────────────────────────────────────────────

model Service {
  id           String   @id @default(cuid())
  name         String
  sellerId     String?  // service creator or seller
  description  String   @db.Text
  images       String[]
  categoryId   String
  group        String
  featured     Boolean  @default(false)
  rating       Float    @default(0)
  reviews      Int      @default(0)
  badge        String?
  includes     String[] // what's covered in the service
  availability String? // e.g. "Mon–Sat, 7am–8pm"
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  options  ServiceOption[]
  bookings ServiceBooking[]
  seller   User?           @relation("SellerServices", fields: [sellerId], references: [id])
  category ServiceCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([sellerId])
  @@index([active, featured])
  @@index([createdAt])
  @@map("services")
}

model ServiceOption {
  id           String      @id @default(cuid())
  serviceId    String
  name         String
  description  String      @db.Text
  pricingType  PricingType
  amount       Int // base price in XAF
  yearlyAmount Int? // for monthly subscriptions with yearly discount
  label        String? // e.g. "Per ride", "Per session"
  duration     String? // e.g. "2 hours", "Full day"
  popular      Boolean     @default(false)
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())

  service  Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings ServiceBooking[]

  @@map("service_options")
}

enum PricingType {
  MONTHLY
  ONE_TIME
  PER_SESSION
}

model ServiceBooking {
  id              String        @id @default(cuid())
  userId          String
  serviceId       String
  serviceOptionId String?
  status          BookingStatus @default(PENDING)
  scheduledAt     DateTime?
  totalPrice      Int
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceOption ServiceOption? @relation(fields: [serviceOptionId], references: [id], onDelete: SetNull)

  @@map("service_bookings")
}

// Update User model - add this relation:
// ─── STORE (Marketplace Seller Profile) ──────────────────────────────────────

model Store {
  id           String   @id @default(cuid())
  userId       String   @unique
    slug         String?  @unique          // ← ADD

  businessName String
  businessType String?   // e.g. "Electronics", "Fashion", "Food"
  image        String?
  location     String?   // e.g. city/town
