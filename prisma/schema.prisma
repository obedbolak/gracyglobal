// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(USER)
  country       String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  counselorProfile Counselor?
  jobApplications  JobApplication[]
  orders           Order[]
  communityPosts   CommunityPost[]
  bookings         Booking[]
  affiliate        Affiliate?
  subscription     Subscription?
  communityMember  CommunityMember?
  enrollments      Enrollment[]
  quizAttempts     QuizAttempt[]
  liveAttendances  LiveAttendance[]

  @@map("users")
}

enum UserRole {
  USER
  COUNSELOR
  ADMIN
  VOLUNTEER
}

// ─── AUTH (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── PLANS & SUBSCRIPTIONS ───────────────────────────────────────────────────

model Plan {
  id                String   @id @default(cuid())
  name              String   @unique  // "free" | "starter" | "growth" | "elite"
  displayName       String            // "Free" | "Starter" | "Growth" | "Elite / Pro"
  description       String
  priceMonthly      Int      @default(0)  // CFA
  priceAnnual       Int      @default(0)  // CFA per month billed annually
  pricePerSession   Int?                  // CFA per session (null = unlimited)
  counselorSessions Int      @default(0)  // sessions per month (0 = unlimited)
  highlighted       Boolean  @default(false)
  active            Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String              @id @default(cuid())
  userId             String              @unique
  planId             String
  billing            SubscriptionBilling @default(MONTHLY)
  status             SubscriptionStatus  @default(ACTIVE)
  currentPeriodStart DateTime            @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean             @default(false)
  sessionsUsed       Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan                  @relation(fields: [planId], references: [id])
  payments SubscriptionPayment[]

  @@map("subscriptions")
}

enum SubscriptionBilling {
  MONTHLY
  ANNUAL
  PER_SESSION
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
}

model SubscriptionPayment {
  id             String        @id @default(cuid())
  subscriptionId String
  amount         Int           // CFA
  method         PayoutMethod
  reference      String?
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_payments")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── COMMUNITY MEMBERSHIP ────────────────────────────────────────────────────

model CommunityMember {
  id            String      @id @default(cuid())
  userId        String      @unique
  bio           String?     @db.Text
  systems       String[]
  badge         MemberBadge @default(CONTRIBUTOR)
  contributions Int         @default(0)
  joinedAt      DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("community_members")
}

enum MemberBadge {
  CONTRIBUTOR
  LEADER
  MENTOR
  PIONEER
}

// ─── COUNSELORS ──────────────────────────────────────────────────────────────

model Counselor {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?  @db.Text
  specialty    String
  rating       Float    @default(0)
  reviews      Int      @default(0)
  pricePerHour Int      @default(0)
  available    Boolean  @default(true)
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("counselors")
}

enum CounselorType {
  RELATIONSHIP
  EMOTIONAL_WELLNESS
  LIFE_COACH
  FAMILY
  CAREER
  MENTAL_HEALTH
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  counselorId String
  type        SessionType
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime
  duration    Int           @default(60)
  price       Int
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id])
  counselor Counselor @relation(fields: [counselorId], references: [id])

  @@map("bookings")
}

enum SessionType {
  TEXT
  VIDEO
  SUPPORT_GROUP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ─── JOBS ────────────────────────────────────────────────────────────────────

model Job {
  id          String      @id @default(cuid())
  title       String
  company     String
  companyLogo String?
  description String      @db.Text
  category    JobCategory
  type        JobType     @default(REMOTE)
  salaryMin   Int?
  salaryMax   Int?
  location    String?
  skills      String[]
  active      Boolean     @default(true)
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  expiresAt   DateTime?

  applications JobApplication[]

  @@map("jobs")
}

enum JobCategory {
  TECH
  MARKETING
  DESIGN
  CUSTOMER_SERVICE
  WRITING
  FINANCE
  EDUCATION
  HEALTH
  OTHER
}

enum JobType {
  REMOTE
  HYBRID
  CONTRACT
  FREELANCE
}

model JobApplication {
  id        String            @id @default(cuid())
  userId    String
  jobId     String
  status    ApplicationStatus @default(APPLIED)
  coverNote String?           @db.Text
  appliedAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@map("job_applications")
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

// ─── MARKETPLACE ─────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  price       Int
  images      String[]
  category    String
  group       String   @default("")
  stock       Int      @default(0)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  rating      Float    @default(0)
  reviews     Int      @default(0)
  badge       String?
  benefits    String[]
  ingredients String[]
  createdAt   DateTime @default(now())

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  total     Int
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── COMMUNITY POSTS ─────────────────────────────────────────────────────────

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  category  String
  tags      String[]
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("community_posts")
}

// ─── STATS ───────────────────────────────────────────────────────────────────

model SiteStat {
  id                String   @id @default(cuid())
  peopleSupported   Int      @default(1000)
  jobsShared        Int      @default(500)
  communityProjects Int      @default(50)
  marketplaceItems  Int      @default(10)
  updatedAt         DateTime @updatedAt

  @@map("site_stats")
}

// ─── AFFILIATE ───────────────────────────────────────────────────────────────

model Affiliate {
  id             String        @id @default(cuid())
  userId         String        @unique
  code           String        @unique
  tier           AffiliateTier @default(STARTER)
  totalReferrals Int           @default(0)
  totalEarnings  Int           @default(0)
  pendingPayout  Int           @default(0)
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals AffiliateReferral[]
  payouts   AffiliatePayout[]

  @@map("affiliates")
}

enum AffiliateTier {
  STARTER
  GROWTH
  ELITE
}

model AffiliateReferral {
  id          String         @id @default(cuid())
  affiliateId String
  referredId  String         @unique
  status      ReferralStatus @default(PENDING)
  commission  Int            @default(0)
  convertedAt DateTime?
  createdAt   DateTime       @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("affiliate_referrals")
}

enum ReferralStatus {
  PENDING
  CONVERTED
  EXPIRED
}

model AffiliatePayout {
  id          String       @id @default(cuid())
  affiliateId String
  amount      Int
  method      PayoutMethod
  reference   String?
  status      PayoutStatus @default(PENDING)
  requestedAt DateTime     @default(now())
  processedAt DateTime?

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("affiliate_payouts")
}

enum PayoutMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  PAYPAL
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ─── E-LEARNING ──────────────────────────────────────────────────────────────

model Course {
  id          String      @id @default(cuid())
  title       String
  description String      @db.Text
  thumbnail   String?
  category    String
  level       CourseLevel @default(BEGINNER)
  price       Int         @default(0) // 0 = free, CFA
  isFree      Boolean     @default(false)
  published   Boolean     @default(false)
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  sections    CourseSection[]
  enrollments Enrollment[]
  liveSession LiveSession?

  @@map("courses")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model CourseSection {
  id       String @id @default(cuid())
  courseId String
  title    String
  order    Int

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("course_sections")
}

model Lesson {
  id          String     @id @default(cuid())
  sectionId   String
  title       String
  type        LessonType
  content     String?    @db.Text // TEXT lessons
  videoUrl    String?              // VIDEO lessons
  duration    Int?                 // minutes
  order       Int
  isFree      Boolean    @default(false) // preview lesson
  publishedAt DateTime?
  createdAt   DateTime   @default(now())

  section  CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quiz     Quiz?
  progress LessonProgress[]

  @@map("lessons")
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  LIVE
}

// ─── QUIZZES ─────────────────────────────────────────────────────────────────

model Quiz {
  id           String @id @default(cuid())
  lessonId     String @unique
  passingScore Int    @default(70) // percentage

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id       String   @id @default(cuid())
  quizId   String
  question String   @db.Text
  options  String[]
  answer   Int      // index of correct option
  order    Int

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  answers     Int[]    // selected option indexes
  score       Int      // percentage
  passed      Boolean
  attemptedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

// ─── LIVE SESSIONS ───────────────────────────────────────────────────────────

model LiveSession {
  id          String            @id @default(cuid())
  courseId    String            @unique
  title       String
  description String?           @db.Text
  scheduledAt DateTime
  duration    Int               @default(60) // minutes
  meetingUrl  String?
  status      LiveSessionStatus @default(SCHEDULED)
  createdAt   DateTime          @default(now())

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendances LiveAttendance[]

  @@map("live_sessions")
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveAttendance {
  id            String   @id @default(cuid())
  liveSessionId String
  userId        String
  joinedAt      DateTime @default(now())

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, userId])
  @@map("live_attendances")
}

// ─── ENROLLMENT & PROGRESS ───────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  paidAmount  Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([userId, courseId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model LessonProgress {
  id           String    @id @default(cuid())
  enrollmentId String
  lessonId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?
  watchedSecs  Int       @default(0) // video lessons

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@map("lesson_progress")
}